# Google Gemini API Key
# 1. https://aistudio.google.com/ 에서 API 키를 발급받으세요.
# 2. Vercel 배포 시 Environment Variables에 GEMINI_API_KEY 이름으로 키를 주입하세요.
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Local Development Port
PORT=8080

# Vercel KV (Redis) Credentials
# Vercel 배포 시 Storage -> KV 데이터베이스를 생성하고 프로젝트에 링크하면
# 아래 환경 변수 4개가 Vercel 프로덕션에 자동으로 주입됩니다.
# 로컬 개발 시 클라우드 Redis에 접근하려면 아래 값들을 실제로 채워주시고,
# 비워두면 자동으로 로컬 인메모리(임시 초기화 구조)로 제한 차단이 동작합니다.
KV_URL=redis://default:...
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here
